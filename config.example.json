{
  "discord_token": "YOUR_BOT_TOKEN",
  "guild_id": 123456789012345678,
  "attempt_prefix": "attempt-",
  "starting_attempt": 1,
  "watch_channel_id": 123456789012345678,
  "public_category_id": 123456789012345678,
  "private_archive_category_id": 123456789012345678,
  "mod_log_channel_id": 123456789012345678,
  "moderator_role_id": 123456789012345678,
  "ollama": {
    "url": "http://127.0.0.1:11434/api/generate",
    "model": "llama3.1:8b",
    "timeout_seconds": 30,
    "prompt_path": "prompt.txt",
    "reason_prompt_path": "reason_prompt.txt"
  },
  "presence": {
    "enabled": true,
    "status": "online",
    "stream_ollama_scoring": true,
    "estimated_total_tokens": 128,
    "update_every_generated_tokens": 4,
    "minimum_update_interval_seconds": 2.0,
    "idle": {
      "activity_type": "watching",
      "template": "#{channel_name}"
    },
    "analyzing": {
      "activity_type": "playing",
      "template": "Analyzing {generated_tokens}/{total_tokens} tokens"
    }
  },
  "thresholds": {
    "trigger_score": 0.91,
    "trigger_score_field": "score",
    "moderator_review_score": 0.65,
    "moderator_review_any_metric_score": 0.75,
    "moderator_review_metric_tags": [
      "severity",
      "targetedness",
      "harassment",
      "threat"
    ],
    "certainty_metric_tag": "certainty",
    "minimum_certainty_for_reset": 0.5,
    "require_all_metrics": false,
    "all_metrics_threshold": 0.91,
    "uncertain_review_certainty_threshold": 0.35,
    "uncertain_review_min_score": 0.45
  },
  "hard_moderation_overrides": {
    "enabled": true,
    "banned_terms": {
      "enabled": true,
      "include_builtin_terms": true,
      "terms": [
        "nigger"
      ],
      "reason": "Message contains a configured banned term.",
      "reset": true
    }
  },
  "warning_reactions": {
    "enabled": true,
    "threshold": [
      0.65,
      0.85
    ],
    "reactions": [
      "⚠️"
    ],
    "use_moderator_review": true,
    "score_field": "score"
  },
  "warning_replies": {
    "enabled": false,
    "threshold": [
      0.75,
      0.85
    ],
    "replies": [
      "{user_mention}, easy there. Score: `{score}`. Severity: `{severity}`. Harassment: `{harassment}`. Threat: `{threat}`.",
      "Warning for {user_mention}: total `{total_score}`. Certainty: `{certainty}`. Reason: {reason}"
    ],
    "allowed_mentions": {
      "users": true,
      "roles": false,
      "everyone": false
    },
    "use_moderator_review": true,
    "score_field": "score"
  },
  "consequence_roles": {
    "enabled": true,
    "tiers": [
      {
        "tier": 1,
        "role_id": 111111111111111111,
        "min_strikes": 1
      },
      {
        "tier": 2,
        "role_id": 222222222222222222,
        "min_strikes": 2
      },
      {
        "tier": 3,
        "role_id": 333333333333333333,
        "min_strikes": 3
      }
    ]
  },
  "new_channel_first_message": {
    "enabled": true,
    "send_on_silent": true,
    "templates": [
      "Everyone thank {user_mention} for ruining it for everyone. Score: `{score}`. Severity: `{severity}`.",
      "{user_mention} got us to **{attempt_name}**. Total: `{total_score}`. Reason: {reason}",
      "Welcome to **{attempt_name}**. The previous attempt was archived. Reason: {reason}"
    ],
    "allowed_mentions": {
      "users": true,
      "roles": false,
      "everyone": false
    }
  },
  "strikes_command": {
    "enabled": true,
    "moderator_only": false,
    "default_limit": 10,
    "max_limit": 25,
    "ephemeral": false,
    "title": "Reset Trigger Leaderboard",
    "empty_message": "No reset-trigger strikes have been recorded yet.",
    "use_mentions": true,
    "show_user_ids": false,
    "show_total": true
  },
  "reset_command": {
    "enabled": true,
    "ephemeral": true,
    "attempt_number": 1,
    "clear_leaderboard": true
  },
  "score_records": {
    "enabled": true,
    "path": "data/message_scores.json",
    "store_message_content": true,
    "store_model_input": false,
    "store_reason": true,
    "max_message_content_length": 2000,
    "pretty_json": true
  },
  "score_command": {
    "enabled": true,
    "moderator_only": false,
    "moderator_permission": "manage_messages",
    "ephemeral": true,
    "title": "Stored moderation score",
    "not_found_message": "No stored score was found for that message. The bot only shows messages it has already scanned.",
    "storage_disabled_message": "Score storage is disabled in the bot config.",
    "show_message_link": true,
    "show_author": true,
    "show_channel": true,
    "show_timestamps": true,
    "show_total_score": true,
    "show_decision_flags": true,
    "show_reason": true,
    "show_message_content": true,
    "max_message_content_length": 800,
    "use_mentions": true,
    "show_metrics": true
  },
  "reason_generation": {
    "enabled": true,
    "generate_for_warning_replies": true,
    "generate_for_resets": true,
    "store_when_generated": true
  },
  "ban": {
    "enabled": false,
    "strikes_required": 3,
    "minimum_score": 0.95
  },
  "dataset": {
    "enabled": true,
    "path": "data/incidents.jsonl",
    "store_message_content": true,
    "store_author_id": true,
    "store_channel_id": true,
    "sample_non_triggered": true,
    "non_triggered_sample_rate": 0.02,
    "minimum_score_to_log_non_triggered": 0.55
  },
  "score_metrics": [
    {
      "tag": "embarrassment",
      "description": "0.0 to 1.0 for how clownable or embarrassing the message is for the sender. This is social/funny cringe, not harm.",
      "weight": 1.0
    },
    {
      "tag": "severity",
      "description": "0.0 to 1.0 for how harmful, policy-bad, cruel, hateful, dangerous, or inappropriate the language/content is.",
      "weight": 2.0
    },
    {
      "tag": "targetedness",
      "description": "0.0 to 1.0 for whether the message is aimed at a real person, Discord user, real group, or protected group. General venting is lower; direct @user or group-directed abuse is higher.",
      "weight": 1.0
    },
    {
      "tag": "harassment",
      "description": "0.0 to 1.0 for abuse, bullying, humiliation, personal attacks, repeated hostility, or targeted cruelty.",
      "weight": 1.5
    },
    {
      "tag": "threat",
      "description": "0.0 to 1.0 for threats of violence or intent to harm. Fictional-character threats score lower than threats toward real people.",
      "weight": 1.5
    },
    {
      "tag": "certainty",
      "description": "0.0 to 1.0 for context certainty / context completeness. 0.0 means important context is missing before taking action; 1.0 means the message itself provides enough context to judge.",
      "weight": 1.0
    }
  ]
}
