{
  "discord_token": "YOUR_BOT_TOKEN",
  "guild_id": 123456789012345678,
  "attempt_prefix": "attempt-",
  "starting_attempt": 1,
  "watch_channel_id": 123456789012345678,
  "public_category_id": 123456789012345678,
  "private_archive_category_id": 123456789012345678,
  "mod_log_channel_id": 123456789012345678,
  "moderator_role_id": 123456789012345678,
  "ollama": {
    "url": "http://127.0.0.1:11434/api/generate",
    "model": "llama3.1:8b",
    "timeout_seconds": 30,
    "prompt_path": "prompt.txt"
  },
  "thresholds": {
    "trigger_score": 0.85,
    "instant_escalation_score": 0.95
  },
  "warning_reactions": {
    "enabled": true,
    "threshold": [
      0.65,
      0.85
    ],
    "reactions": [
      "⚠️"
    ]
  },
  "warning_replies": {
    "enabled": false,
    "threshold": [
      0.75,
      0.85
    ],
    "replies": [
      "{user_mention}, easy there. Category: **{category}**. Score: `{score}`. Reason: {reason}",
      "Warning for {user_mention}: this scored `{score}` for **{category}**."
    ],
    "allowed_mentions": {
      "users": true,
      "roles": false,
      "everyone": false
    }
  },
  "consequence_roles": {
    "enabled": true,
    "tiers": [
      {
        "tier": 1,
        "role_id": 111111111111111111,
        "min_strikes": 1
      },
      {
        "tier": 2,
        "role_id": 222222222222222222,
        "min_strikes": 2
      },
      {
        "tier": 3,
        "role_id": 333333333333333333,
        "min_strikes": 3
      }
    ]
  },
  "new_channel_first_message": {
    "enabled": true,
    "send_on_silent": true,
    "templates": [
      "Everyone thank {user_mention} for ruining it for everyone. Reason: {reason}",
      "{user_mention} got us to **{attempt_name}**. Category: **{category}**. Score: `{score}`",
      "Welcome to **{attempt_name}**. The previous attempt was archived for: **{category}**"
    ],
    "allowed_mentions": {
      "users": true,
      "roles": false,
      "everyone": false
    }
  },
  "strikes_command": {
    "enabled": true,
    "moderator_only": false,
    "default_limit": 10,
    "max_limit": 25,
    "ephemeral": false,
    "title": "Reset Trigger Leaderboard",
    "empty_message": "No reset-trigger strikes have been recorded yet.",
    "use_mentions": true,
    "show_user_ids": false,
    "show_total": true
  },
  "ban": {
    "enabled": false,
    "strikes_required": 3,
    "minimum_score": 0.95
  },
  "dataset": {
    "enabled": true,
    "path": "data/incidents.jsonl",
    "store_message_content": true,
    "store_author_id": true,
    "store_channel_id": true,
    "sample_non_triggered": true,
    "non_triggered_sample_rate": 0.02,
    "minimum_score_to_log_non_triggered": 0.55
  },
  "archive": {
    "preserve_trigger_message": true
  }
}
